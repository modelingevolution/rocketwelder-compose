# RocketWelder compose environment overrides.
#
# Copy to `.env` next to docker-compose.yml; Docker Compose picks it up
# automatically. Anything set here overrides the in-image defaults; leaving a
# variable absent keeps the default the welder ships with.

# --- epic-035 (LLM into RocketWelder2) -------------------------------------

# Claude API key — required for the AI Chat page (/ai/chat) to actually call
# Anthropic. Without it the page renders but every send returns an error. Keep
# this OUT of git history; populate the real key in .env (gitignored) only.
# CLAUDE_API_KEY=sk-ant-...

# AI Chat / IDE chat library configuration. Defaults below match the in-app
# defaults; explicit here for documentation. Override only when needed.
# Claude__ApiKey=${CLAUDE_API_KEY}
# Claude__Model=claude-sonnet-4-20250514

# On-disk system-prompt directory mounted from ./prompts on the host (see the
# bind mount in docker-compose.yml). The in-app default is already /prompts;
# this is here for completeness and so an alternate mount path works without
# rebuilding the image.
# RocketWelder__Prompts__Path=/prompts
# RocketWelder__Prompts__AiChat=ai-chat.md
